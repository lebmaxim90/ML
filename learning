from pycocotools.coco import COCO
coco = COCO(PATH_TO_JSON)

# Получаем все категории
categories = coco.loadCats(coco.getCatIds())
cat_id_to_name = {cat['id']: cat['name'] for cat in categories}
cat_name_to_yolo_id = {name: idx for idx, (_, name) in enumerate(cat_id_to_name.items())}

print(f"   Найдено классов: {len(categories)}")
print(f"   Примеры классов: {list(cat_name_to_yolo_id.keys())[:10]}")
print(f"\n4. Конвертация аннотаций в YOLO формат...")

# Получаем все изображения
img_ids = coco.getImgIds()
print(f"   Всего изображений: {len(img_ids)}")

# Возьмем первые 500 для скорости
img_ids = img_ids[:500]
converted = 0

for img_id in img_ids:
    # Информация об изображении
    img_info = coco.loadImgs(img_id)[0]
    img_filename = img_info['file_name']
    img_width = img_info['width']
    img_height = img_info['height']
    
    # Аннотации для этого изображения
    ann_ids = coco.getAnnIds(imgIds=img_id)
    anns = coco.loadAnns(ann_ids)
    
    # Создаем .txt файл (все в val для простоты)
    txt_filename = os.path.splitext(img_filename)[0] + '.txt'
    txt_path = os.path.join(f"{BASE_DIR}/labels/val", txt_filename)
    
    with open(txt_path, 'w') as f:
        for ann in anns:
            # COCO bbox: [x, y, width, height]
            x, y, w, h = ann['bbox']
            
            # Конвертируем в YOLO формат: [x_center, y_center, width, height] (нормализованные)
            x_center = (x + w/2) / img_width
            y_center = (y + h/2) / img_height
            w_norm = w / img_width
            h_norm = h / img_height
            
            # Ограничиваем значения от 0 до 1
            x_center = max(0, min(1, x_center))
            y_center = max(0, min(1, y_center))
            w_norm = max(0, min(1, w_norm))
            h_norm = max(0, min(1, h_norm))
            
            # Получаем class_id
            cat_name = cat_id_to_name[ann['category_id']]
            class_id = cat_name_to_yolo_id[cat_name]
            
            f.write(f"{class_id} {x_center:.6f} {y_center:.6f} {w_norm:.6f} {h_norm:.6f}\n")
    
    # Копируем изображение
    src_img = os.path.join(PATH_TO_IMAGES, img_filename)
    dst_img = os.path.join(f"{BASE_DIR}/images/val", img_filename)
    if os.path.exists(src_img):
        shutil.copy2(src_img, dst_img)
    
    converted += 1
    if converted % 50 == 0:
        print(f"   Обработано {converted}/{len(img_ids)} изображений")

